    "blood_pressure_systolic = np.random.randint(90, 180, n_samples)  # Systolic BP\n",
    "blood_pressure_diastolic = np.random.randint(60, 120, n_samples)  # Diastolic BP\n",
    "cholesterol = np.random.randint(100, 300, n_samples)  # Cholesterol level\n",
    "glucose = np.random.randint(80, 300, n_samples)  # Blood glucose\n",
    "bmi = np.random.uniform(18, 45, n_samples)  # BMI\n",
    "heart_rate = np.random.randint(40, 120, n_samples)  # Heart rate (bpm)\n",
    "comorbidities = np.random.randint(0, 5, n_samples)  # Number of comorbidities\n",
    "smoke_years = np.random.randint(0, 60, n_samples)  # Years of smoking\n",
    "\n",
    "# Create mortality label based on features (realistic relationship)\n",
    "# Higher mortality risk with: older age, high BP, high cholesterol, high glucose, high BMI, comorbidities\n",
    "mortality = (\n",
    "    (age > 60).astype(int) * 0.3 +\n",
    "    (blood_pressure_systolic > 140).astype(int) * 0.2 +\n",
    "    (cholesterol > 240).astype(int) * 0.15 +\n",
    "    (glucose > 200).astype(int) * 0.25 +\n",
    "    (bmi > 30).astype(int) * 0.2 +\n",
    "    (comorbidities > 2).astype(int) * 0.25 +\n",
    "    (smoke_years > 20).astype(int) * 0.15\n",
    ")\n",
    "\n",
    "# Add some randomness and convert to binary (0 or 1)\n",
    "mortality_prob = mortality + np.random.uniform(-0.1, 0.1, n_samples)\n",
    "mortality_prob = np.clip(mortality_prob, 0, 1)\n",
    "mortality_binary = (mortality_prob > 0.5).astype(int)\n",
    "\n",
    "# Create DataFrame\n",
    "df = pd.DataFrame({\n",
    "    'age': age,\n",
    "    'systolic_bp': blood_pressure_systolic,\n",
    "    'diastolic_bp': blood_pressure_diastolic,\n",
    "    'cholesterol': cholesterol,\n",
    "    'glucose': glucose,\n",
    "    'bmi': bmi,\n",
    "    'heart_rate': heart_rate,\n",
    "    'comorbidities': comorbidities,\n",
    "    'smoke_years': smoke_years,\n",
