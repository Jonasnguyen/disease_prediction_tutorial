    "# Evaluation function\n",
    "def evaluate_model(model, X_test, y_test, device):\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        X_test = X_test.to(device)\n",
    "        outputs = model(X_test)\n",
    "        probabilities = torch.softmax(outputs, dim=1)\n",
    "        predictions = torch.argmax(outputs, dim=1)\n",
    "    \n",
    "    return predictions.cpu().numpy(), probabilities.cpu().numpy()\n",
    "\n",
    "# Evaluate PyTorch model\n",
    "y_pred_pytorch, y_pred_proba_pytorch = evaluate_model(model, X_test_tensor, y_test_tensor, device)\n",
    "\n",
    "# Calculate metrics\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"PYTORCH MODEL EVALUATION\")\n",
    "print(\"=\"*50)\n",
    "print(f\"\\nAccuracy: {accuracy_score(y_test, y_pred_pytorch):.4f}\")\n",
    "print(f\"Precision: {precision_score(y_test, y_pred_pytorch):.4f}\")\n",
    "print(f\"Recall: {recall_score(y_test, y_pred_pytorch):.4f}\")\n",
    "print(f\"F1-Score: {f1_score(y_test, y_pred_pytorch):.4f}\")\n",
    "print(f\"ROC-AUC Score: {roc_auc_score(y_test, y_pred_proba_pytorch[:, 1]):.4f}\")\n",
    "\n",
    "print(\"\\nConfusion Matrix:\")\n",
    "cm_pytorch = confusion_matrix(y_test, y_pred_pytorch)\n",
    "print(cm_pytorch)\n",
    "\n",
    "print(\"\\nClassification Report:\")\n",
    "print(classification_report(y_test, y_pred_pytorch, target_names=['Low Risk', 'High Risk']))"
